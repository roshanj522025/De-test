{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "privileged": true,
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "noVNC",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "runArgs": ["--cap-add=SYS_ADMIN"],
  "postCreateCommand": "mkdir -p ~/.vnc && printf 'password\\n' | vncpasswd -f > ~/.vnc/passwd && chmod 600 ~/.vnc/passwd && git clone https://github.com/novnc/noVNC.git",
  "postStartCommand": "vncserver -xstartup \"cinnamon-session\" -rfbport 5900 && ./noVNC/utils/novnc_proxy --vnc 127.0.0.1:5900 --listen 0.0.0.0:6080"
}
